{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfdevjyoti"
		},
		"LS_sadevkpidashboardingnew_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_sadevkpidashboardingnew'"
		},
		"LS_sgkpidashboarding_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_sgkpidashboarding'"
		},
		"LS_sgkpidashboardingnew_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_sgkpidashboardingnew'"
		},
		"LS_sqlserverkpidashboarding_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_sqlserverkpidashboarding'"
		},
		"LS_sadevkpidashboardingnew_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sadevkpidashboardingnew.dfs.core.windows.net/"
		},
		"LS_sgkpidashboarding_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sadevkpidashboardingnew.dfs.core.windows.net/"
		},
		"LS_sgkpidashboardingnew_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sadevkpidashboardingnew.dfs.core.windows.net/"
		},
		"LS_sqlserverkpidashboarding_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserverkpidashboarding.database.windows.net"
		},
		"LS_sqlserverkpidashboarding_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqlserverkpidashboarding"
		},
		"LS_sqlserverkpidashboarding_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "cloud"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfdevjyoti_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_sadevkpidashboardingnew_accountKey": {
						"value": "[parameters('LS_sadevkpidashboardingnew_accountKey')]"
					},
					"LS_sgkpidashboarding_accountKey": {
						"value": "[parameters('LS_sgkpidashboarding_accountKey')]"
					},
					"LS_sgkpidashboardingnew_accountKey": {
						"value": "[parameters('LS_sgkpidashboardingnew_accountKey')]"
					},
					"LS_sqlserverkpidashboarding_password": {
						"value": "[parameters('LS_sqlserverkpidashboarding_password')]"
					},
					"LS_sadevkpidashboardingnew_properties_typeProperties_url": {
						"value": "[parameters('LS_sadevkpidashboardingnew_properties_typeProperties_url')]"
					},
					"LS_sgkpidashboarding_properties_typeProperties_url": {
						"value": "[parameters('LS_sgkpidashboarding_properties_typeProperties_url')]"
					},
					"LS_sgkpidashboardingnew_properties_typeProperties_url": {
						"value": "[parameters('LS_sgkpidashboardingnew_properties_typeProperties_url')]"
					},
					"LS_sqlserverkpidashboarding_properties_typeProperties_server": {
						"value": "[parameters('LS_sqlserverkpidashboarding_properties_typeProperties_server')]"
					},
					"LS_sqlserverkpidashboarding_properties_typeProperties_database": {
						"value": "[parameters('LS_sqlserverkpidashboarding_properties_typeProperties_database')]"
					},
					"LS_sqlserverkpidashboarding_properties_typeProperties_userName": {
						"value": "[parameters('LS_sqlserverkpidashboarding_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}